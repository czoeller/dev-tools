# GitHub username or organization owning the repositories.
GITHUB_OWNER=czoeller

# path to private-key.asc
GPG_PRIVATE_KEY_FILE=./private-key.asc

# GPG private-key passphrase.
# Quote it if it contains spaces or shell-special characters.
SIGNING_PASSWORD='replace-with-your-passphrase'

# One repository per line.
#
# Entries without an owner use GITHUB_OWNER.
# Fully-qualified owner/repository entries are also supported.
REPOSITORIES='
project-one
project-two
gradle-plugin-example
other-owner/another-project
'